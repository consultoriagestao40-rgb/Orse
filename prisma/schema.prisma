// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                  String                    @id @default(cuid())
  nomeFantasia        String
  cnpj                String                    @unique
  ativo               Boolean                   @default(true)
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  // Novos campos de controle do WhatsApp
  whatsappInstanceId  String?
  whatsappToken       String?
  whatsappClientToken String?
  whatsappConnected   Boolean                   @default(false)
  whatsappPhone       String?
  plano               String                    @default("STARTER") // STARTER, PRO, ENTERPRISE
  limiteUsuarios      Int                       @default(3)
  trialStartedAt      DateTime?
  taxaWhatsapp        Float                     @default(130.0)
  asaasCustomerId     String?                   @unique
  users               User[]
  clients             Client[]
  leads               Lead[]
  propostas           Proposta[]
  contratos           Contrato[]
  produtos            Produto[]
  documentos          DocumentoProposta[]
  ccts                CCT[]
  composicoes         EquipeTecnicaComposicao[]
  templatesProposta   TemplatePropostaComercial[]
  templatesContrato   TemplateContrato[]
  escalas             Escala[]
  activities          Activity[]
  comments            Comment[]
  cobrancas           Cobranca[]
}

model EmpresaEmissora {
  id           String   @id @default(uuid())
  nomeFantasia String
  razaoSocial  String
  cnpj         String
  endereco     String?
  telefone     String?
  email        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  contratos    Contrato[]
  documentosProposta DocumentoProposta[] @relation("EmpresaToDocumento")
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  nome           String
  password       String          @default("123456")
  role           UserRole        @default(USER)
  cargo          String?
  celular        String?
  managerId      String?
  createdAt      DateTime        @default(now())
  propostas      Proposta[]
  manager        User?           @relation("UserToManager", fields: [managerId], references: [id])
  subordinates   User[]          @relation("UserToManager")
  propostaShares PropostaShare[]
  auditLogs      AuditLog[]
  leads          Lead[]
  leadShares     LeadShare[]
  activities     Activity[]
  comments       Comment[]
  files          FileAttachment[]
  whatsappMessages WhatsAppMessage[]
  notifications  Notification[]
  smtpAccounts   SmtpAccount[]
  avatarUrl      String?
  tenantId       String?
  tenant         Tenant?         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Client {
  id           String     @id @default(cuid())
  codigo       Int        @unique @default(autoincrement())
  nomeFantasia String
  razaoSocial  String?
  cnpj         String?    @unique
  email        String?
  whatsapp     String?
  endereco     String?
  contato      String?
  createdAt    DateTime   @default(now())
  propostas    Proposta[]
  contratos    Contrato[]
  documentosProposta DocumentoProposta[] @relation("ClientToDocumento")
  tenantId     String?
  tenant       Tenant?            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model CCT {
  id                     String   @id @default(cuid())
  nome                   String
  uf                     String   @default("PR")
  cidade                 String?
  vigenciaInicio         DateTime
  vigenciaFim            DateTime
  vaValor                Float    @default(0)
  vaTipo                 String   @default("DIARIO")
  vaProvisFerias         Boolean  @default(false)
  vaDescPercent          Float    @default(0)
  vtValor                Float    @default(0)
  vtDescPercent          Float    @default(6)
  examesMedicos          Float    @default(0)
  seguroVida             Float    @default(0)
  cestaBasica            Float    @default(0)
  provisFerias           Float    @default(11.11)
  provis13               Float    @default(8.33)
  provisRescisao         Float    @default(0)
  encargoInss            Float    @default(20)
  encargoFgts            Float    @default(8)
  encargoRat             Float    @default(0)
  pis                    Float    @default(0.65)
  cofins                 Float    @default(3)
  iss                    Float    @default(5)
  margemLucro            Float    @default(10)
  taxaAdm                Float    @default(5)
  createdAt              DateTime @default(now())
  uniformeEpi            Float    @default(0)
  custosSindicato        Float    @default(0)
  manutencaoEquipamentos Float    @default(0)
  outrosBeneficios       Float    @default(0)
  reservaTecnica         Float    @default(0)
  insalubridadeBase      String   @default("MINIMO") // "SALARIO" ou "MINIMO"
  salarioMinimo          Float    @default(1412)
  cargos                 Cargo[]
  tenantId               String?
  tenant                 Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Cargo {
  id                   String @id @default(cuid())
  cctId                String
  nome                 String
  pisoSalarial         Float  @default(0)
  adicionalCopa        Float  @default(0)
  gratificacoes        Float  @default(0)
  assiduidade          Float  @default(0)
  insalubridadePercent Float  @default(0)
  episConfig           Json?
  cct                  CCT    @relation(fields: [cctId], references: [id], onDelete: Cascade)
}

model Proposta {
  id        String           @id @default(cuid())
  numero    Int              @unique @default(autoincrement())
  userId    String
  clientId  String?
  status    String           @default("ATIVO")
  createdAt DateTime         @default(now())
  client    Client?          @relation(fields: [clientId], references: [id])
  user      User             @relation(fields: [userId], references: [id])
  versoes   PropostaVersao[]
  shares    PropostaShare[]
  auditLogs AuditLog[]
  contrato  Contrato?
  documentosComerciais DocumentoProposta[] @relation("FpvToDocumento")
  tenantId  String?
  tenant    Tenant?            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model PropostaVersao {
  id          String         @id @default(cuid())
  propostaId  String
  versao      Int            @default(1)
  impostos    Json
  margens     Json
  metadados   Json?
  custoTotal  Float
  precoVenda  Float
  dataCriacao DateTime       @default(now())
  items       PropostaItem[]
  proposta    Proposta       @relation(fields: [propostaId], references: [id], onDelete: Cascade)
}

model PropostaItem {
  id               String         @id @default(cuid())
  versaoId         String
  nomeCargo        String
  quantidade       Int            @default(1)
  escala           String         @default("5x2")
  entrada          String?        @default("08:00")
  saida            String?        @default("17:00")
  configFinanceira Json
  ativosConfig     Json
  custoDireto      Float
  custoTotalItem   Float
  versao           PropostaVersao @relation(fields: [versaoId], references: [id], onDelete: Cascade)

  // Novos campos para a modalidade Spot
  tipoItem             String         @default("POSTO_FIXO") // "POSTO_FIXO" ou "SPOT"
  unidadeMedida        String?        // "HORA" ou "DIA"
  quantidadeDemanda    Float?         // Ex: 5 (dias) ou 40 (horas)
  precoUnitarioDemanda Float?         // Preço cobrado do cliente por diária/hora
  comissaoVendedorPct  Float          @default(0)
  equipeTecnicaId      String?
  equipeTecnica        EquipeTecnicaComposicao? @relation(fields: [equipeTecnicaId], references: [id])
}

model Escala {
  id                 String   @id @default(cuid())
  nome               String   @unique
  diasTrabalhadosMes Int      @default(22)
  horasMensais       Int      @default(220)
  createdAt          DateTime @default(now())
  tenantId           String?
  tenant             Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model PropostaStatus {
  id    String @id @default(cuid())
  nome  String @unique
  color String @default("bg-slate-100 text-slate-600 border border-slate-200")
}

model Produto {
  id            String   @id @default(cuid())
  codigo        Int      @unique @default(autoincrement())
  descricao     String
  unidade       String   @default("UN")
  precoUnitario Float    @default(0)
  categoria     String   @default("Geral")
  ativo         Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tenantId      String?
  tenant        Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Categoria {
  id   String @id @default(cuid())
  nome String @unique
}

model UnidadeMedida {
  id   String @id @default(cuid())
  nome String @unique
}

enum UserRole {
  ADMIN
  MANAGER
  USER
}

model TipoServico {
  id   String @id @default(cuid())
  nome String @unique
}

model Segmento {
  id   String @id @default(cuid())
  nome String @unique
}

model PropostaShare {
  id         String   @id @default(cuid())
  propostaId String
  userId     String
  createdAt  DateTime @default(now())

  proposta Proposta @relation(fields: [propostaId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([propostaId, userId])
}

model AuditLog {
  id         String   @id @default(cuid())
  propostaId String
  userId     String // Quem realizou a ação
  action     String // Ex: 'CREATE', 'TRANSFER', 'SHARE', 'STATUS_CHANGE', 'VERSION_SAVE'
  details    Json? // Detalhes extras (ex: de quem para quem foi transferido)
  createdAt  DateTime @default(now())

  proposta Proposta @relation(fields: [propostaId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])
}

model TemplateContrato {
  id        String             @id @default(uuid())
  nome      String             @unique
  clausulas ClausulaTemplate[]
  createdAt DateTime           @default(now())
  tenantId  String?
  tenant    Tenant?            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model ClausulaTemplate {
  id         String           @id @default(uuid())
  templateId String
  ordem      Int              @default(0)
  titulo     String
  texto      String
  template   TemplateContrato @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model Contrato {
  id                String             @id @default(cuid())
  propostaId        String             @unique
  clientId          String
  empresaEmissoraId String
  templateOrigemId  String?
  status            String             @default("Pendente de Assinatura") // Pendente de Assinatura, Vigente, Encerrado, Reajuste Pendente
  dataInicio        DateTime?
  vigenciaMeses     Int                @default(12)
  dataReajuste      DateTime?
  indiceReajuste    String?            @default("IPCA")
  valorMensal       Float              @default(0)
  valorTotal        Float              @default(0)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  proposta        Proposta         @relation(fields: [propostaId], references: [id], onDelete: Cascade)
  client          Client           @relation(fields: [clientId], references: [id])
  empresaEmissora EmpresaEmissora  @relation(fields: [empresaEmissoraId], references: [id])
  clausulas       ClausulaContrato[]
  tenantId        String?
  tenant          Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model ClausulaContrato {
  id         String   @id @default(uuid())
  contratoId String
  ordem      Int      @default(0)
  titulo     String
  texto      String
  contrato   Contrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)
}

model TemplatePropostaComercial {
  id        String             @id @default(uuid())
  nome      String             @unique
  tipo      String             @default("A4") // "A4" ou "SLIDE_DECK"
  secoes    SecaoTemplateProposta[]
  createdAt DateTime           @default(now())
  tenantId  String?
  tenant    Tenant?            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model SecaoTemplateProposta {
  id         String                    @id @default(uuid())
  templateId String
  ordem      Int                       @default(0)
  titulo     String
  texto      String
  template   TemplatePropostaComercial @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model DocumentoProposta {
  id                String             @id @default(cuid())
  propostaId        String
  clientId          String
  empresaEmissoraId String
  templateOrigemId  String?
  tipo              String             @default("A4") // "A4" ou "SLIDE_DECK"
  configApresentacao Json?
  status            String             @default("Rascunho")
  valorTotal        Float              @default(0)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  proposta        Proposta         @relation("FpvToDocumento", fields: [propostaId], references: [id], onDelete: Cascade)
  client          Client           @relation("ClientToDocumento", fields: [clientId], references: [id])
  empresaEmissora EmpresaEmissora  @relation("EmpresaToDocumento", fields: [empresaEmissoraId], references: [id])
  secoes          SecaoDocumentoProposta[]
  tenantId        String?
  tenant          Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model SecaoDocumentoProposta {
  id         String            @id @default(uuid())
  documentoId String
  ordem      Int               @default(0)
  titulo     String
  texto      String
  documento  DocumentoProposta @relation(fields: [documentoId], references: [id], onDelete: Cascade)
}

model LeadStage {
  id        String   @id @default(cuid())
  nome      String
  ordem     Int      @default(0)
  color     String   @default("bg-slate-100")
  createdAt DateTime @default(now())
  leads     Lead[]
}

model Lead {
  id           String        @id @default(cuid())
  nomeFantasia String
  razaoSocial  String?
  cnpj         String?
  email        String?
  telefone     String?
  endereco     String?
  cidade       String?
  uf           String?
  segmento     String?
  contatoNome  String?
  valorEst     Float         @default(0)
  stageId      String
  assignedToId String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  typingStatus String?
  typingUpdatedAt DateTime?

  stage        LeadStage     @relation(fields: [stageId], references: [id])
  assignedTo   User?         @relation(fields: [assignedToId], references: [id])
  history      LeadHistory[]
  shares       LeadShare[]
  activities   Activity[]
  comments     Comment[]
  files        FileAttachment[]
  whatsappMessages WhatsAppMessage[]
  contacts     LeadContact[]
  tenantId     String?
  tenant       Tenant?         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model LeadContact {
  id        String   @id @default(cuid())
  leadId    String
  nome      String
  telefone  String?
  email     String?
  cargo     String?
  createdAt DateTime @default(now())

  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
}


model LeadHistory {
  id        String   @id @default(cuid())
  leadId    String
  tipo      String   // Ex: 'LIGACAO', 'EMAIL', 'REUNIAO', 'ANOTACAO', 'MUDANCA_FASE', 'PROSPECCAO'
  descricao String
  createdAt DateTime @default(now())

  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model LeadShare {
  id        String   @id @default(cuid())
  leadId    String
  userId    String
  createdAt DateTime @default(now())

  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([leadId, userId])
}

model Activity {
  id          String   @id @default(cuid())
  leadId      String?
  userId      String
  titulo      String
  descricao   String?
  tipo        String   @default("REUNIAO") // REUNIAO, LIGACAO, EMAIL, TAREFA
  dataInicio  DateTime
  dataFim     DateTime
  status      String   @default("PENDENTE") // PENDENTE, CONCLUIDA, CANCELADA
  createdAt   DateTime @default(now())

  lead        Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId    String?
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Comment {
  id          String   @id @default(cuid())
  leadId      String
  userId      String
  texto       String
  createdAt   DateTime @default(now())

  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId    String?
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model FileAttachment {
  id          String   @id @default(cuid())
  leadId      String
  userId      String
  nome        String
  tamanho     Int      // bytes
  tipo        String   // mimetype
  base64Data  String   @db.Text
  createdAt   DateTime @default(now())

  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WhatsAppMessage {
  id          String   @id @default(cuid())
  leadId      String
  userId      String?  // Pode ser nulo se foi o cliente quem enviou
  messageId   String?  @unique // ID da mensagem na Z-API para evitar duplicidade
  texto       String   @db.Text
  direction   String   // 'INBOUND' (cliente -> empresa) ou 'OUTBOUND' (empresa -> cliente)
  status      String   @default("SENT") // SENT, DELIVERED, READ (para outbound)
  createdAt   DateTime @default(now())

  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id])
}

model SmtpAccount {
  id        String   @id @default(cuid())
  nome      String   // Ex: "Suporte SmartBid"
  host      String   // smtp.titan.email
  port      Int      @default(587)
  user      String   // suporte@smartbid.com
  password  String   // Senha SMTP
  fromEmail String   // suporte@smartbid.com
  fromName  String   // SmartBid
  active    Boolean  @default(true)
  imapHost  String?  // Ex: imap.umbler.com
  imapPort  Int?     @default(993)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String?
  userRel   User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  texto     String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EquipeTecnicaComposicao {
  id                     String         @id @default(cuid())
  nome                   String         @unique
  custoMensalMaoObra     Float          @default(0)
  custoMensalVeiculo     Float          @default(0)
  custoMensalCombustivel Float          @default(0)
  custoMensalTotal       Float          @default(0)
  valorDiariaSugerido    Float          @default(0)
  valorHoraSugerido      Float          @default(0)
  itensMaoObra           Json           // [{ cargoId: "...", quantidade: 1 }]
  itensCustosAdicionais  Json?          // [{ descricao: "...", valor: 0 }]
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  propostaItems          PropostaItem[]
  tenantId               String?
  tenant                 Tenant?        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model ProspectCache {
  id           String   @id @default(cuid())
  termo        String
  localizacao  String
  nomeFantasia String
  endereco     String?
  telefone     String?
  site         String?
  porte        String?
  avaliacoes   Int      @default(0)
  segmento     String?
  createdAt    DateTime @default(now())

  @@unique([termo, localizacao, nomeFantasia])
}

model Cobranca {
  id             String    @id @default(cuid())
  tenantId       String
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plano          String    // TESTE, STARTER, PRO, ENTERPRISE
  valor          Float
  status         String    // PAGO, PENDENTE, ATRASADO
  metodo         String    // PIX, CARTAO, MANUAL
  dataVencimento DateTime
  dataPagamento  DateTime?
  asaasPaymentId String?   @unique
  createdAt      DateTime  @default(now())
}

model PlanoConfig {
  id             String   @id @default(cuid())
  nome           String   @unique // e.g. "BASICO", "PRO", "ENTERPRISE"
  label          String   // e.g. "Básico", "Profissional (PRO)", "Enterprise"
  preco          Float    // e.g. 149.00, 299.00, 599.00
  limiteUsuarios Int      // e.g. 3, 10, 100
  descricao      String
  features       String   // Comma-separated features or lines
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}



// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                  String                    @id @default(cuid())
  nomeFantasia        String
  cnpj                String                    @unique
  logoUrl             String?
  primaryColor        String?                   @default("#1B4D3E")
  ativo               Boolean                   @default(true)
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  // Novos campos de controle do WhatsApp
  whatsappInstanceId  String?
  whatsappToken       String?
  whatsappClientToken String?
  whatsappConnected   Boolean                   @default(false)
  whatsappPhone       String?
  plano                     String                    @default("STARTER") // STARTER, PRO, ENTERPRISE
  limiteUsuarios            Int                       @default(3)
  limitePesquisasProspeccao Int                       @default(30)
  trialStartedAt            DateTime?
  taxaWhatsapp              Float                     @default(130.0)
  asaasCustomerId           String?                   @unique
  users                     User[]
  clients                   Client[]
  leads                     Lead[]
  pipelines                 Pipeline[]
  propostas                 Proposta[]
  contratos                 Contrato[]
  produtos                  Produto[]
  documentos                DocumentoProposta[]
  ccts                      CCT[]
  composicoes               EquipeTecnicaComposicao[]
  templatesProposta         TemplatePropostaComercial[]
  templatesContrato         TemplateContrato[]
  escalas                   Escala[]
  activities                Activity[]
  comments                  Comment[]
  cobrancas                 Cobranca[]
  faqs                      FaqPadrao[]
  prospectSearchLogs        ProspectSearchLog[]
  atas                      Ata[]
  tasks                     Task[]
  taskStages                TaskStage[]
  tags                      Tag[]
  taskTemplates             TaskTemplate[]
  pics                      Pic[]
  picStages                 PicStage[]
  categoriasAtivo           CategoriaAtivo[]
  ativos                    Ativo[]
  templatesComodato         TemplateComodato[]
  contratosComodato         ContratoComodato[]
  ordensServicoAtivo        OrdemServicoAtivo[]
  empresasEmissoras         EmpresaEmissora[]
}

model EmpresaEmissora {
  id           String   @id @default(uuid())
  nomeFantasia String
  razaoSocial  String
  cnpj         String
  endereco     String?
  telefone     String?
  email        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  contratos    Contrato[]
  documentosProposta DocumentoProposta[] @relation("EmpresaToDocumento")
  contratosComodato   ContratoComodato[]
  
  tenantId     String?
  tenant       Tenant?    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  nome           String
  password       String          @default("123456")
  role           UserRole        @default(USER)
  cargo          String?
  celular        String?
  managerId      String?
  createdAt      DateTime        @default(now())
  propostas      Proposta[]
  manager        User?           @relation("UserToManager", fields: [managerId], references: [id])
  subordinates   User[]          @relation("UserToManager")
  propostaShares PropostaShare[]
  auditLogs      AuditLog[]
  leads          Lead[]
  leadShares     LeadShare[]
  activities     Activity[]
  comments       Comment[]
  files          FileAttachment[]
  whatsappMessages WhatsAppMessage[]
  notifications  Notification[]
  smtpAccounts   SmtpAccount[]
  avatarUrl      String?
  color          String?         @default("slate")
  tenantId                 String?
  tenant                   Tenant?           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sentInternalMessages     InternalMessage[] @relation("SentInternalMessages")
  receivedInternalMessages InternalMessage[] @relation("ReceivedInternalMessages")
  prospectSearchLogs       ProspectSearchLog[]
  ataAcoes                 AtaAcao[]
  createdTasks             Task[]            @relation("TaskCreator")
  assignedTasks            Task[]            @relation("TaskAssignee")
  taskParticipants         TaskParticipant[]
  taskObservers            TaskObserver[]
  taskComments             TaskComment[]
  taskAttachments          TaskAttachment[]
  taskActivities           TaskActivity[]
  taskHistories            TaskHistory[]
  taskViews                TaskView[]
  picActions               PicAction[]
}

model Client {
  id           String     @id @default(cuid())
  codigo       Int        @unique @default(autoincrement())
  nomeFantasia String
  razaoSocial  String?
  cnpj         String?    @unique
  email        String?
  whatsapp     String?
  endereco     String?
  contato      String?
  contatoCargo String?
  segmento     String?
  createdAt    DateTime   @default(now())
  propostas    Proposta[]
  contratos    Contrato[]
  documentosProposta DocumentoProposta[] @relation("ClientToDocumento")
  contratosComodato   ContratoComodato[]
  ordensServicoAtivo  OrdemServicoAtivo[]
  tenantId     String?
  tenant       Tenant?            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model CCT {
  id                     String   @id @default(cuid())
  nome                   String
  uf                     String   @default("PR")
  cidade                 String?
  vigenciaInicio         DateTime
  vigenciaFim            DateTime
  vaValor                Float    @default(0)
  vaTipo                 String   @default("DIARIO")
  vaProvisFerias         Boolean  @default(false)
  vaDescPercent          Float    @default(0)
  vtValor                Float    @default(0)
  vtDescPercent          Float    @default(6)
  examesMedicos          Float    @default(0)
  seguroVida             Float    @default(0)
  cestaBasica            Float    @default(0)
  provisFerias           Float    @default(11.11)
  provis13               Float    @default(8.33)
  provisRescisao         Float    @default(0)
  encargoInss            Float    @default(20)
  encargoFgts            Float    @default(8)
  encargoRat             Float    @default(0)
  pis                    Float    @default(0.65)
  cofins                 Float    @default(3)
  iss                    Float    @default(5)
  margemLucro            Float    @default(10)
  taxaAdm                Float    @default(5)
  createdAt              DateTime @default(now())
  uniformeEpi            Float    @default(0)
  custosSindicato        Float    @default(0)
  manutencaoEquipamentos Float    @default(0)
  outrosBeneficios       Float    @default(0)
  reservaTecnica         Float    @default(0)
  insalubridadeBase      String   @default("MINIMO") // "SALARIO" ou "MINIMO"
  salarioMinimo          Float    @default(1412)
  cargos                 Cargo[]
  tenantId               String?
  tenant                 Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Cargo {
  id                   String @id @default(cuid())
  cctId                String
  nome                 String
  pisoSalarial         Float  @default(0)
  adicionalCopa        Float  @default(0)
  gratificacoes        Float  @default(0)
  assiduidade          Float  @default(0)
  insalubridadePercent Float  @default(0)
  episConfig           Json?
  cct                  CCT    @relation(fields: [cctId], references: [id], onDelete: Cascade)
}

model Proposta {
  id        String           @id @default(cuid())
  numero    Int              @unique @default(autoincrement())
  userId    String
  clientId  String?
  status    String           @default("ATIVO")
  createdAt DateTime         @default(now())
  client    Client?          @relation(fields: [clientId], references: [id])
  user      User             @relation(fields: [userId], references: [id])
  versoes   PropostaVersao[]
  shares    PropostaShare[]
  auditLogs AuditLog[]
  contrato  Contrato?
  documentosComerciais DocumentoProposta[] @relation("FpvToDocumento")
  tenantId  String?
  tenant    Tenant?            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model PropostaVersao {
  id          String         @id @default(cuid())
  propostaId  String
  versao      Int            @default(1)
  impostos    Json
  margens     Json
  metadados   Json?
  custoTotal  Float
  precoVenda  Float
  dataCriacao DateTime       @default(now())
  items       PropostaItem[]
  proposta    Proposta       @relation(fields: [propostaId], references: [id], onDelete: Cascade)
}

model PropostaItem {
  id               String         @id @default(cuid())
  versaoId         String
  nomeCargo        String
  quantidade       Int            @default(1)
  escala           String         @default("5x2")
  entrada          String?        @default("08:00")
  saida            String?        @default("17:00")
  configFinanceira Json
  ativosConfig     Json
  custoDireto      Float
  custoTotalItem   Float
  versao           PropostaVersao @relation(fields: [versaoId], references: [id], onDelete: Cascade)

  // Novos campos para a modalidade Spot
  tipoItem             String         @default("POSTO_FIXO") // "POSTO_FIXO" ou "SPOT"
  unidadeMedida        String?        // "HORA" ou "DIA"
  quantidadeDemanda    Float?         // Ex: 5 (dias) ou 40 (horas)
  precoUnitarioDemanda Float?         // Preço cobrado do cliente por diária/hora
  comissaoVendedorPct  Float          @default(0)
  equipeTecnicaId      String?
  equipeTecnica        EquipeTecnicaComposicao? @relation(fields: [equipeTecnicaId], references: [id])
}

model Escala {
  id                 String   @id @default(cuid())
  nome               String   @unique
  diasTrabalhadosMes Int      @default(22)
  horasMensais       Int      @default(220)
  createdAt          DateTime @default(now())
  tenantId           String?
  tenant             Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model PropostaStatus {
  id    String  @id @default(cuid())
  nome  String  @unique
  color String  @default("bg-slate-100 text-slate-600 border border-slate-200")
  ativo Boolean @default(true)
}

model DocumentoStatus {
  id    String  @id @default(cuid())
  nome  String  @unique
  color String  @default("bg-slate-100 text-slate-600 border border-slate-200")
  ativo Boolean @default(true)
}


model Produto {
  id            String   @id @default(cuid())
  codigo        Int      @unique @default(autoincrement())
  descricao     String
  unidade       String   @default("UN")
  precoUnitario Float    @default(0)
  categoria     String   @default("Geral")
  ativo         Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tenantId      String?
  tenant        Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Categoria {
  id    String  @id @default(cuid())
  nome  String  @unique
  ativo Boolean @default(true)
}

model UnidadeMedida {
  id    String  @id @default(cuid())
  nome  String  @unique
  ativo Boolean @default(true)
}

enum UserRole {
  ADMIN
  MANAGER
  USER
}

model TipoServico {
  id    String  @id @default(cuid())
  nome  String  @unique
  ativo Boolean @default(true)
}

model Segmento {
  id    String  @id @default(cuid())
  nome  String  @unique
  ativo Boolean @default(true)
}

model PropostaShare {
  id         String   @id @default(cuid())
  propostaId String
  userId     String
  role       String   @default("PARTICIPANTE") // "PARTICIPANTE" ou "OBSERVADOR"
  createdAt  DateTime @default(now())

  proposta Proposta @relation(fields: [propostaId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([propostaId, userId])
}

model AuditLog {
  id         String   @id @default(cuid())
  propostaId String
  userId     String // Quem realizou a ação
  action     String // Ex: 'CREATE', 'TRANSFER', 'SHARE', 'STATUS_CHANGE', 'VERSION_SAVE'
  details    Json? // Detalhes extras (ex: de quem para quem foi transferido)
  createdAt  DateTime @default(now())

  proposta Proposta @relation(fields: [propostaId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])
}

model TemplateContrato {
  id        String             @id @default(uuid())
  nome      String             @unique
  clausulas ClausulaTemplate[]
  createdAt DateTime           @default(now())
  tenantId  String?
  tenant    Tenant?            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model ClausulaTemplate {
  id         String           @id @default(uuid())
  templateId String
  ordem      Int              @default(0)
  titulo     String
  texto      String
  template   TemplateContrato @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model Contrato {
  id                String             @id @default(cuid())
  propostaId        String             @unique
  clientId          String
  empresaEmissoraId String
  templateOrigemId  String?
  status            String             @default("Pendente de Assinatura") // Pendente de Assinatura, Vigente, Encerrado, Reajuste Pendente
  dataInicio        DateTime?
  vigenciaMeses     Int                @default(12)
  dataReajuste      DateTime?
  indiceReajuste    String?            @default("IPCA")
  valorMensal       Float              @default(0)
  valorTotal        Float              @default(0)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  proposta        Proposta         @relation(fields: [propostaId], references: [id], onDelete: Cascade)
  client          Client           @relation(fields: [clientId], references: [id])
  empresaEmissora EmpresaEmissora  @relation(fields: [empresaEmissoraId], references: [id])
  clausulas       ClausulaContrato[]
  tenantId        String?
  tenant          Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pic             Pic?
}

model ClausulaContrato {
  id         String   @id @default(uuid())
  contratoId String
  ordem      Int      @default(0)
  titulo     String
  texto      String
  contrato   Contrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)
}

model TemplatePropostaComercial {
  id        String             @id @default(uuid())
  nome      String             @unique
  tipo      String             @default("A4") // "A4" ou "SLIDE_DECK"
  secoes    SecaoTemplateProposta[]
  createdAt DateTime           @default(now())
  tenantId  String?
  tenant    Tenant?            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model SecaoTemplateProposta {
  id         String                    @id @default(uuid())
  templateId String
  ordem      Int                       @default(0)
  titulo     String
  texto      String
  template   TemplatePropostaComercial @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model DocumentoProposta {
  id                String             @id @default(cuid())
  propostaId        String
  clientId          String
  empresaEmissoraId String
  templateOrigemId  String?
  tipo              String             @default("A4") // "A4" ou "SLIDE_DECK"
  configApresentacao Json?
  status            String             @default("Rascunho")
  valorTotal        Float              @default(0)
  
  // Campos de Assinatura e Aceite Eletrônico
  statusAssinatura  String?            // "PENDENTE", "ASSINADO", "RECUSADO"
  dataAssinatura    DateTime?
  assinaturaBase64  String?
  ipAssinante       String?
  nomeAssinante     String?
  cpfAssinante      String?

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  proposta        Proposta         @relation("FpvToDocumento", fields: [propostaId], references: [id], onDelete: Cascade)
  client          Client           @relation("ClientToDocumento", fields: [clientId], references: [id])
  empresaEmissora EmpresaEmissora  @relation("EmpresaToDocumento", fields: [empresaEmissoraId], references: [id])
  secoes          SecaoDocumentoProposta[]
  tenantId        String?
  tenant          Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model SecaoDocumentoProposta {
  id         String            @id @default(uuid())
  documentoId String
  ordem      Int               @default(0)
  titulo     String
  texto      String
  documento  DocumentoProposta @relation(fields: [documentoId], references: [id], onDelete: Cascade)
}

model Pipeline {
  id        String      @id @default(cuid())
  nome      String
  tenantId  String?
  tenant    Tenant?     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stages    LeadStage[]
  leads     Lead[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model LeadStage {
  id         String    @id @default(cuid())
  nome       String
  ordem      Int       @default(0)
  color      String    @default("bg-slate-100")
  createdAt  DateTime  @default(now())
  pipelineId String?
  pipeline   Pipeline? @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  leads      Lead[]
}

model Lead {
  id           String        @id @default(cuid())
  codigo       Int           @unique @default(autoincrement())
  nomeFantasia String
  razaoSocial  String?
  cnpj         String?
  email        String?
  telefone     String?
  endereco     String?
  cidade       String?
  uf           String?
  segmento     String?
  contatoNome  String?
  valorEst     Float         @default(0)
  stageId      String
  pipelineId   String?
  assignedToId String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  typingStatus String?
  typingUpdatedAt DateTime?

  stage        LeadStage     @relation(fields: [stageId], references: [id])
  pipeline     Pipeline?     @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  assignedTo   User?         @relation(fields: [assignedToId], references: [id])
  history      LeadHistory[]
  shares       LeadShare[]
  activities   Activity[]
  comments     Comment[]
  files        FileAttachment[]
  whatsappMessages WhatsAppMessage[]
  contacts     LeadContact[]
  tenantId     String?
  tenant       Tenant?         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model LeadContact {
  id        String   @id @default(cuid())
  leadId    String
  nome      String
  telefone  String?
  email     String?
  cargo     String?
  createdAt DateTime @default(now())

  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
}


model LeadHistory {
  id        String   @id @default(cuid())
  leadId    String
  tipo      String   // Ex: 'LIGACAO', 'EMAIL', 'REUNIAO', 'ANOTACAO', 'MUDANCA_FASE', 'PROSPECCAO'
  descricao String
  createdAt DateTime @default(now())

  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model LeadShare {
  id        String   @id @default(cuid())
  leadId    String
  userId    String
  role       String   @default("PARTICIPANTE") // "PARTICIPANTE" ou "OBSERVADOR"
  createdAt DateTime @default(now())

  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([leadId, userId])
}

model Activity {
  id          String   @id @default(cuid())
  leadId      String?
  userId      String
  titulo      String
  descricao   String?
  tipo        String   @default("REUNIAO") // REUNIAO, LIGACAO, EMAIL, TAREFA
  dataInicio  DateTime
  dataFim     DateTime
  status      String   @default("PENDENTE") // PENDENTE, CONCLUIDA, CANCELADA
  createdAt   DateTime @default(now())

  lead        Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId      String?
  task        Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tenantId    String?
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Comment {
  id          String   @id @default(cuid())
  leadId      String
  userId      String
  texto       String
  createdAt   DateTime @default(now())

  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId    String?
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model FileAttachment {
  id          String   @id @default(cuid())
  leadId      String
  userId      String
  nome        String
  tamanho     Int      // bytes
  tipo        String   // mimetype
  base64Data  String   @db.Text
  createdAt   DateTime @default(now())

  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WhatsAppMessage {
  id          String   @id @default(cuid())
  leadId      String
  userId      String?  // Pode ser nulo se foi o cliente quem enviou
  messageId   String?  @unique // ID da mensagem na Z-API para evitar duplicidade
  texto       String   @db.Text
  direction   String   // 'INBOUND' (cliente -> empresa) ou 'OUTBOUND' (empresa -> cliente)
  status      String   @default("SENT") // SENT, DELIVERED, READ (para outbound)
  createdAt   DateTime @default(now())

  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id])
}

model SmtpAccount {
  id        String   @id @default(cuid())
  nome      String   // Ex: "Suporte SmartBid"
  host      String   // smtp.titan.email
  port      Int      @default(587)
  user      String   // suporte@smartbid.com
  password  String   // Senha SMTP
  fromEmail String   // suporte@smartbid.com
  fromName  String   // SmartBid
  active    Boolean  @default(true)
  imapHost  String?  // Ex: imap.umbler.com
  imapPort  Int?     @default(993)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String?
  userRel   User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  texto     String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EquipeTecnicaComposicao {
  id                     String         @id @default(cuid())
  nome                   String         @unique
  custoMensalMaoObra     Float          @default(0)
  custoMensalVeiculo     Float          @default(0)
  custoMensalCombustivel Float          @default(0)
  custoMensalTotal       Float          @default(0)
  valorDiariaSugerido    Float          @default(0)
  valorHoraSugerido      Float          @default(0)
  itensMaoObra           Json           // [{ cargoId: "...", quantidade: 1 }]
  itensCustosAdicionais  Json?          // [{ descricao: "...", valor: 0 }]
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  propostaItems          PropostaItem[]
  tenantId               String?
  tenant                 Tenant?        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model ProspectCache {
  id           String   @id @default(cuid())
  termo        String
  localizacao  String
  nomeFantasia String
  endereco     String?
  telefone     String?
  site         String?
  porte        String?
  avaliacoes   Int      @default(0)
  segmento     String?
  createdAt    DateTime @default(now())

  @@unique([termo, localizacao, nomeFantasia])
}

model Cobranca {
  id             String    @id @default(cuid())
  tenantId       String
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plano          String    // TESTE, STARTER, PRO, ENTERPRISE
  valor          Float
  status         String    // PAGO, PENDENTE, ATRASADO
  metodo         String    // PIX, CARTAO, MANUAL
  dataVencimento DateTime
  dataPagamento  DateTime?
  asaasPaymentId String?   @unique
  createdAt      DateTime  @default(now())
}

model PlanoConfig {
  id             String   @id @default(cuid())
  nome           String   @unique // e.g. "BASICO", "PRO", "ENTERPRISE"
  label          String   // e.g. "Básico", "Profissional (PRO)", "Enterprise"
  preco          Float    // e.g. 149.00, 299.00, 599.00
  limiteUsuarios Int      // e.g. 3, 10, 100
  descricao      String
  features       String   // Comma-separated features or lines
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model FaqPadrao {
  id        String   @id @default(cuid())
  pergunta  String
  resposta  String   @db.Text
  ordem     Int      @default(0)
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InternalMessage {
  id          String   @id @default(cuid())
  senderId    String
  receiverId  String
  content     String   @db.Text
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  sender      User     @relation("SentInternalMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver    User     @relation("ReceivedInternalMessages", fields: [receiverId], references: [id], onDelete: Cascade)
}

model ProspectSearchLog {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String
  termo       String
  localizacao String
  resultados  Int      @default(0)
  createdAt   DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Ata {
  id                      String      @id @default(cuid())
  titulo                  String
  dataReuniou             DateTime
  horaReuniou             String?     // Horário da reunião (ex: "10:30")
  local                   String?
  pautas                  Json        // Array de pautas principais: ["Pauta 1", "Pauta 2"]
  participantesPresentes  Json        // Array de participantes: [{ userId: "...", nome: "...", departamento: "...", email: "...", presente: boolean }]
  
  // Relatório da Reunião
  relatorio               String?     @db.Text // Texto formatado do Rich Text Editor do relatório
  pautasDeliberativas     Json?       // [{ item: "...", descricao: "...", status: "...", anotacao: "..." }]
  consideracoes           String      @db.Text // Texto formatado do Rich Text Editor das considerações
  
  // Próxima Reunião
  proximaReuniaoData      DateTime?
  proximaReuniaoHora      String?
  proximaReuniaoLocal     String?
  
  categoria               String?     @default("Geral")
  status                  String      @default("Rascunho")
  justificativaFinalizacao String?    @db.Text
  criadorNome             String?
  
  acoes                   AtaAcao[]
  
  versao                  Int         @default(1)
  parentAtaId             String?
  parentAta               Ata?        @relation("AtaVersoes", fields: [parentAtaId], references: [id], onDelete: Cascade)
  versoes                 Ata[]       @relation("AtaVersoes")
  
  tenantId                String?
  tenant                  Tenant?     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
}

model AtaAcao {
  id            String      @id @default(cuid())
  ataId         String
  ata           Ata         @relation(fields: [ataId], references: [id], onDelete: Cascade)
  item          String?     // Número do item, ex: "1", "2"
  descricao     String
  responsavelId String
  responsavel   User        @relation(fields: [responsavelId], references: [id], onDelete: Cascade)
  dataLimite    DateTime
  numBitrix     String?     // Número do Bitrix
  concluida     Boolean     @default(false)
  concluidaEm   DateTime?
  comentarios   Json?       // Array de comentários: [{ id: "...", autor: "...", autorAvatar: "...", texto: "...", data: "..." }]
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model TaskStage {
  id         String    @id @default(cuid())
  nome       String
  ordem      Int       @default(0)
  color      String    @default("bg-slate-100")
  tenantId   String?
  tenant     Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tasks      Task[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Task {
  id            String             @id @default(cuid())
  codigo        Int                @unique @default(autoincrement())
  titulo        String
  descricao     String?            @db.Text
  status        String             @default("PENDENTE") // PENDENTE, EM_ANDAMENTO, CONCLUIDA, CANCELADA
  prioridade    String             @default("MEDIA") // BAIXA, MEDIA, ALTA
  vencimento    DateTime?
  stageId       String
  stage         TaskStage          @relation(fields: [stageId], references: [id])
  criadorId     String
  criador       User               @relation("TaskCreator", fields: [criadorId], references: [id])
  responsavelId String?
  responsavel   User?              @relation("TaskAssignee", fields: [responsavelId], references: [id])
  
  participantes TaskParticipant[]
  observadores  TaskObserver[]
  atividades    TaskActivity[]
  comments      TaskComment[]
  attachments   TaskAttachment[]
  history       TaskHistory[]
  tags          TaskTag[]
  calendarEvents Activity[]
  views         TaskView[]
  
  recorrente            Boolean   @default(false)
  recorrenciaFrequencia String?
  recorrenciaIntervalo  Int?      @default(1)
  recorrenciaProximaData DateTime?
  recorrenciaFim        DateTime?

  tenantId      String?
  tenant        Tenant?            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model TaskParticipant {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([taskId, userId])
}

model TaskObserver {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([taskId, userId])
}

model TaskActivity {
  id            String    @id @default(cuid())
  taskId        String
  task          Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  titulo        String
  descricao     String?   @db.Text
  concluida     Boolean   @default(false)
  responsavelId String?
  responsavel   User?     @relation(fields: [responsavelId], references: [id])
  vencimento    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model TaskComment {
  id         String   @id @default(cuid())
  taskId     String
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  texto      String   @db.Text
  createdAt  DateTime @default(now())
}

model TaskAttachment {
  id         String   @id @default(cuid())
  taskId     String
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  nome       String
  tamanho    Int      // bytes
  tipo       String   // mimetype
  base64Data String   @db.Text
  createdAt  DateTime @default(now())
}

model TaskHistory {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tipo      String   // Ex: 'CRIACAO', 'MUDANCA_ETAPA', 'COMENTARIO', 'ATIVIDADE', 'ANEXO', 'ALTERACAO_DADOS'
  descricao String   @db.Text
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
}

model Tag {
  id        String    @id @default(cuid())
  nome      String
  color     String    @default("#64748B")
  tenantId  String?
  tenant    Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tasks     TaskTag[]
  createdAt DateTime  @default(now())
}

model TaskTag {
  id     String @id @default(cuid())
  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tagId  String
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([taskId, tagId])
}

model TaskTemplate {
  id            String   @id @default(cuid())
  titulo        String
  descricao     String?  @db.Text
  prioridade    String   @default("MEDIA") // BAIXA, MEDIA, ALTA
  responsavelId String?
  
  activities    String?  @db.Text // JSON list of subtask titles: ["Subtask 1", "Subtask 2"]
  tagIds        String?  @db.Text // JSON list of tag IDs: ["tag-id-1", "tag-id-2"]
  
  tenantId      String?
  tenant        Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model TaskView {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  viewedAt  DateTime @default(now())

  @@unique([taskId, userId])
}

model PicStage {
  id        String   @id @default(cuid())
  nome      String
  color     String   @default("#64748B")
  ordem     Int      @default(0)
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pics      Pic[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Pic {
  id                   String   @id @default(cuid())
  contratoId           String   @unique
  contrato             Contrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  status               String   @default("ATIVO") // ATIVO, SUSPENSO, ARQUIVADO
  stageId              String
  stage                PicStage @relation(fields: [stageId], references: [id])
  anotacoes            String?  @db.Text
  relatorioReuniao     String?  @db.Text
  tenantId             String?
  tenant               Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  // Dados Financeiros (editáveis)
  valorMensal                  Float    @default(0)
  periodoMedicaoInicio        String?
  periodoMedicaoFim           String?
  dataFaturamento             String?
  documentacoesMensais        String?  @db.Text
  prazoPagamento              String?
  dataPagamento               String?
  faturamentoCnpj             String?
  faturamentoRazaoSocial      String?
  faturamentoEndereco         String?
  faturamentoInscricaoEstadual  String?
  faturamentoInscricaoMunicipal String?
  faturamentoEmail            String?

  // Relações
  funcionarios  PicEmployee[]
  equipamentos  PicEquipment[]
  materiais     PicMaterial[]
  secoes        PicSection[]
}

model PicEmployee {
  id             String  @id @default(cuid())
  picId          String
  pic            Pic     @relation(fields: [picId], references: [id], onDelete: Cascade)
  funcao         String
  quantidade     Int     @default(1)
  escala         String  @default("5x2")
  horarioEntrada String? @default("08:00")
  horarioSaida   String? @default("17:00")
  diasSemana     String? @default("Segunda a Sexta")
}

model PicEquipment {
  id         String  @id @default(cuid())
  picId      String
  pic        Pic     @relation(fields: [picId], references: [id], onDelete: Cascade)
  nome       String
  quantidade Int     @default(1)
  tipo       String  @default("PROPRIO") // PROPRIO, LOCADO
  observacao String?
}

model PicMaterial {
  id         String  @id @default(cuid())
  picId      String
  pic        Pic     @relation(fields: [picId], references: [id], onDelete: Cascade)
  nome       String
  quantidade Int     @default(1)
  unidade    String? @default("UN")
  observacao String?
}

model PicSection {
  id    String      @id @default(cuid())
  picId String
  pic   Pic         @relation(fields: [picId], references: [id], onDelete: Cascade)
  nome  String
  ordem Int         @default(0)
  acoes PicAction[]
}

model PicAction {
  id            String     @id @default(cuid())
  secaoId       String
  secao         PicSection @relation(fields: [secaoId], references: [id], onDelete: Cascade)
  descricao     String
  responsavelId String?
  responsavel   User?      @relation(fields: [responsavelId], references: [id], onDelete: SetNull)
  dataLimite    DateTime?
  observacao    String?    @db.Text
  status        String     @default("PENDENTE") // PENDENTE, CONCLUIDA
  ordem         Int        @default(0)
}

model CategoriaAtivo {
  id        String   @id @default(cuid())
  nome      String
  ativo     Boolean  @default(true)
  ativos    Ativo[]
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([nome, tenantId])
}

model Ativo {
  id                   String               @id @default(cuid())
  codigo               String               @unique // ex: ATV-0001
  descricao            String
  valor                Float                @default(0)
  status               String               @default("DISPONIVEL") // DISPONIVEL, COMODATO, MANUTENCAO, BAIXADO
  observacao           String?              @db.Text
  categoriaId          String
  categoria            CategoriaAtivo       @relation(fields: [categoriaId], references: [id])
  tenantId             String?
  tenant               Tenant?              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contratosItem        ContratoComodatoItem[]
  ordensServico        OrdemServicoAtivo[]  @relation("AtivoToOS")
  ordensServicoDestino OrdemServicoAtivo[]  @relation("AtivoDestinoToOS")
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
}

model TemplateComodato {
  id        String                     @id @default(uuid())
  nome      String
  clausulas ClausulaTemplateComodato[]
  tenantId  String?
  tenant    Tenant?                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime                   @default(now())
  updatedAt DateTime                   @updatedAt

  @@unique([nome, tenantId])
}

model ClausulaTemplateComodato {
  id         String           @id @default(uuid())
  templateId String
  template   TemplateComodato @relation(fields: [templateId], references: [id], onDelete: Cascade)
  ordem      Int              @default(0)
  titulo     String
  texto      String           @db.Text
}

model ContratoComodato {
  id                String                     @id @default(cuid())
  codigo            Int                        @unique @default(autoincrement())
  clientId          String
  client            Client                     @relation(fields: [clientId], references: [id])
  empresaEmissoraId String
  empresaEmissora   EmpresaEmissora            @relation(fields: [empresaEmissoraId], references: [id])
  status            String                     @default("RASCUNHO") // RASCUNHO, VIGENTE, SUSPENSO, ENCERRADO, VENCIDO
  dataInicio        DateTime
  vigenciaMeses     Int                        @default(12)
  dataVencimento    DateTime?
  valorMinimoMensal Float                      @default(250.00)
  clausulas         ClausulaContratoComodato[]
  itens             ContratoComodatoItem[]
  ordensServico     OrdemServicoAtivo[]
  tenantId          String?
  tenant            Tenant?                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
}

model ContratoComodatoItem {
  id                 String           @id @default(cuid())
  contratoComodatoId String
  contratoComodato   ContratoComodato @relation(fields: [contratoComodatoId], references: [id], onDelete: Cascade)
  ativoId            String
  ativo              Ativo            @relation(fields: [ativoId], references: [id])
  quantidade         Int              @default(1)
  valorUnitario      Float            @default(0)
}

model ClausulaContratoComodato {
  id                 String           @id @default(uuid())
  contratoComodatoId String
  contratoComodato   ContratoComodato @relation(fields: [contratoComodatoId], references: [id], onDelete: Cascade)
  ordem              Int              @default(0)
  titulo             String
  texto              String           @db.Text
}

model OrdemServicoAtivo {
  id                 String            @id @default(cuid())
  codigo             Int               @unique @default(autoincrement()) // OS Nº 320
  tipo               String            // INSTALACAO, RETIRADA, TROCA, MANUTENCAO
  contratoComodatoId String
  contratoComodato   ContratoComodato  @relation(fields: [contratoComodatoId], references: [id], onDelete: Cascade)
  clientId           String
  client             Client            @relation(fields: [clientId], references: [id])
  ativoId            String
  ativo              Ativo             @relation("AtivoToOS", fields: [ativoId], references: [id])
  ativoDestinoId     String?
  ativoDestino       Ativo?            @relation("AtivoDestinoToOS", fields: [ativoDestinoId], references: [id])
  status             String            @default("PENDENTE") // PENDENTE, PROGRAMADO, EM_ANDAMENTO, VALIDACAO, CONCLUIDA, CANCELADA
  dataEmissao        DateTime          @default(now())
  dataPrevista       DateTime?
  observacao         String?           @db.Text
  instrucoes         String?           @db.Text
  tecnicoResponsavel String?
  tecnicoEmail       String?
  observacaoAtendimento String?        @db.Text
  fotosAtendimento   String?           @db.Text // JSON string containing base64 images
  assinaturaCliente  String?           @db.Text // Base64 signature drawing
  nomeAssinante      String?
  cpfAssinante       String?
  tenantId           String?
  tenant             Tenant?           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
}

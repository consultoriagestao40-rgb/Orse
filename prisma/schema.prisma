// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model EmpresaEmissora {
  id           String   @id @default(uuid())
  nomeFantasia String
  razaoSocial  String
  cnpj         String
  endereco     String?
  telefone     String?
  email        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  nome           String
  password       String          @default("123456")
  role           UserRole        @default(USER)
  cargo          String?
  celular        String?
  managerId      String?
  createdAt      DateTime        @default(now())
  propostas      Proposta[]
  manager        User?           @relation("UserToManager", fields: [managerId], references: [id])
  subordinates   User[]          @relation("UserToManager")
  propostaShares PropostaShare[]
  auditLogs      AuditLog[]
}

model Client {
  id           String     @id @default(cuid())
  nomeFantasia String
  razaoSocial  String?
  cnpj         String?    @unique
  email        String?
  whatsapp     String?
  endereco     String?
  contato      String?
  createdAt    DateTime   @default(now())
  propostas    Proposta[]
}

model CCT {
  id                     String   @id @default(cuid())
  nome                   String
  uf                     String   @default("PR")
  cidade                 String?
  vigenciaInicio         DateTime
  vigenciaFim            DateTime
  vaValor                Float    @default(0)
  vaTipo                 String   @default("DIARIO")
  vaProvisFerias         Boolean  @default(false)
  vaDescPercent          Float    @default(0)
  vtValor                Float    @default(0)
  vtDescPercent          Float    @default(6)
  examesMedicos          Float    @default(0)
  seguroVida             Float    @default(0)
  cestaBasica            Float    @default(0)
  provisFerias           Float    @default(11.11)
  provis13               Float    @default(8.33)
  provisRescisao         Float    @default(0)
  encargoInss            Float    @default(20)
  encargoFgts            Float    @default(8)
  encargoRat             Float    @default(0)
  pis                    Float    @default(0.65)
  cofins                 Float    @default(3)
  iss                    Float    @default(5)
  margemLucro            Float    @default(10)
  taxaAdm                Float    @default(5)
  createdAt              DateTime @default(now())
  uniformeEpi            Float    @default(0)
  custosSindicato        Float    @default(0)
  manutencaoEquipamentos Float    @default(0)
  outrosBeneficios       Float    @default(0)
  reservaTecnica         Float    @default(0)
  insalubridadeBase      String   @default("MINIMO") // "SALARIO" ou "MINIMO"
  salarioMinimo          Float    @default(1412)
  cargos                 Cargo[]
}

model Cargo {
  id                   String @id @default(cuid())
  cctId                String
  nome                 String
  pisoSalarial         Float  @default(0)
  adicionalCopa        Float  @default(0)
  gratificacoes        Float  @default(0)
  assiduidade          Float  @default(0)
  insalubridadePercent Float  @default(0)
  episConfig           Json?
  cct                  CCT    @relation(fields: [cctId], references: [id], onDelete: Cascade)
}

model Proposta {
  id        String           @id @default(cuid())
  numero    Int              @unique @default(autoincrement())
  userId    String
  clientId  String?
  status    String           @default("ATIVO")
  createdAt DateTime         @default(now())
  client    Client?          @relation(fields: [clientId], references: [id])
  user      User             @relation(fields: [userId], references: [id])
  versoes   PropostaVersao[]
  shares    PropostaShare[]
  auditLogs AuditLog[]
}

model PropostaVersao {
  id          String         @id @default(cuid())
  propostaId  String
  versao      Int            @default(1)
  impostos    Json
  margens     Json
  metadados   Json?
  custoTotal  Float
  precoVenda  Float
  dataCriacao DateTime       @default(now())
  items       PropostaItem[]
  proposta    Proposta       @relation(fields: [propostaId], references: [id], onDelete: Cascade)
}

model PropostaItem {
  id               String         @id @default(cuid())
  versaoId         String
  nomeCargo        String
  quantidade       Int            @default(1)
  escala           String         @default("5x2")
  entrada          String?        @default("08:00")
  saida            String?        @default("17:00")
  configFinanceira Json
  ativosConfig     Json
  custoDireto      Float
  custoTotalItem   Float
  versao           PropostaVersao @relation(fields: [versaoId], references: [id], onDelete: Cascade)
}

model Escala {
  id                 String   @id @default(cuid())
  nome               String   @unique
  diasTrabalhadosMes Int      @default(22)
  horasMensais       Int      @default(220)
  createdAt          DateTime @default(now())
}

model PropostaStatus {
  id    String @id @default(cuid())
  nome  String @unique
  color String @default("bg-slate-100 text-slate-600 border border-slate-200")
}

model Produto {
  id            String   @id @default(cuid())
  codigo        Int      @unique @default(autoincrement())
  descricao     String
  unidade       String   @default("UN")
  precoUnitario Float    @default(0)
  categoria     String   @default("Geral")
  ativo         Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Categoria {
  id   String @id @default(cuid())
  nome String @unique
}

model UnidadeMedida {
  id   String @id @default(cuid())
  nome String @unique
}

enum UserRole {
  ADMIN
  MANAGER
  USER
}

model TipoServico {
  id   String @id @default(cuid())
  nome String @unique
}

model Segmento {
  id   String @id @default(cuid())
  nome String @unique
}

model PropostaShare {
  id         String   @id @default(cuid())
  propostaId String
  userId     String
  createdAt  DateTime @default(now())

  proposta Proposta @relation(fields: [propostaId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([propostaId, userId])
}

model AuditLog {
  id         String   @id @default(cuid())
  propostaId String
  userId     String // Quem realizou a ação
  action     String // Ex: 'CREATE', 'TRANSFER', 'SHARE', 'STATUS_CHANGE', 'VERSION_SAVE'
  details    Json? // Detalhes extras (ex: de quem para quem foi transferido)
  createdAt  DateTime @default(now())

  proposta Proposta @relation(fields: [propostaId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])
}
